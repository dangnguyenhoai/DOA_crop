import random

# Danh sách ví dụ
my_list = [1, 2, 3, 4, 5, "hello", "world"]

# Lấy giá trị ngẫu nhiên
random_value = random.choice(my_list)

# Lấy index của giá trị ngẫu nhiên
index_of_value = my_list.index(random_value)

# Thay thế giá trị tại index đó
my_list[index_of_value] = "new_value"

print("Danh sách sau khi thay đổi:", my_list)
